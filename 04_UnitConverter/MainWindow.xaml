<Window x:Class="UnitConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UnitConverter"
        mc:Ignorable="d"
        Title="単位変換アプリ" Height="320" Width="250"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <!-- <summary>単位変換アプリのメインウィンドウ</summary> -->
    <Window.DataContext>
        <local:MainWindowViewModel />
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- カテゴリ選択 -->
        <ComboBox Grid.Row="0" Margin="0,0,0,10" Height="28" 
                  ItemsSource="{Binding Categories}" 
                  SelectedItem="{Binding SelectedCategory}"/>
        <!-- 入力欄と単位選択 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <StackPanel>
                <TextBox Width="70" Height="28" Margin="0,0,0,5" 
                         Text="{Binding LeftValue, UpdateSourceTrigger=PropertyChanged}" 
                         PreviewTextInput="TextBox_PreviewTextInput" 
                         MaxLength="10"/>
                <ComboBox Width="70" Height="28" 
                          ItemsSource="{Binding LeftUnits}" 
                          SelectedItem="{Binding SelectedLeftUnit}"/>
            </StackPanel>
            <StackPanel Margin="10,0" VerticalAlignment="Center">
                <Button Content="→" Width="30" Height="28" Command="{Binding ConvertRightCommand}"/>
                <Button Content="←" Width="30" Height="28" Command="{Binding ConvertLeftCommand}" Margin="0,5,0,0"/>
            </StackPanel>
            <StackPanel>
                <TextBox Width="70" Height="28" Margin="0,0,0,5" 
                         Text="{Binding RightValue, UpdateSourceTrigger=PropertyChanged}" 
                         PreviewTextInput="TextBox_PreviewTextInput" 
                         MaxLength="10"/>
                <ComboBox Width="70" Height="28" 
                          ItemsSource="{Binding RightUnits}" 
                          SelectedItem="{Binding SelectedRightUnit}"/>
            </StackPanel>
        </StackPanel>
        <!-- 警告表示 -->
        <TextBlock Grid.Row="2" Text="{Binding WarningMessage}" Foreground="Red" FontSize="12" HorizontalAlignment="Center"/>
    </Grid>
</Window>
